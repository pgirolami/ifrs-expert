# LLM Provider Configuration
# Set to: openai, openai-codex, anthropic, mistral, minimax, or ollama
LLM_PROVIDER=openai



# OpenAI Configuration
# Set the OPENAI_API_KEY environment key
OPENAI_MODEL=gpt-5.4

# OpenAI Codex Configuration
# Requires `codex login` and uses ~/.codex/auth.json by default
# Set CODEX_AUTH_FILE only if you want to override that path
OPENAI_CODEX_MODEL=gpt-5.4

# Anthropic Configuration
# Set the ANTHROPIC_API_KEY environment key
ANTHROPIC_MODEL=opus-4.6

# Mistral Configuration
# Set the MISTRAL_API_KEY environment key
MISTRAL_MODEL=mistral-large-latest

# Minimax Configuration
# Set the MINIMAX_API_KEY environment key
MINIMAX_MODEL=abab6.5s-chat

# Ollama Configuration
# OLLAMA_API_KEY is optional and defaults to 'ollama' because Ollama ignores it.
# OLLAMA_BASE_URL is optional and defaults to http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
